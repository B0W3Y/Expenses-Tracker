# ---- Server ----
NODE_ENV="development"
PORT=3000
# Comma-separated list of allowed origins, or "*" for any.
CORS_ORIGIN="*"

# ---- Database ----
# Matches the credentials in the root docker-compose.yml.
DATABASE_URL="postgresql://expense_tracker:expense_tracker@localhost:5432/expense_tracker?schema=public"

# ---- Auth ----
# Use a long, random secret in production (e.g. `openssl rand -hex 32`).
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
